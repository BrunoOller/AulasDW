@{
    ViewData["Title"] = "Dashboard";
}

<h2 class="mb-4">Dashboard — Luminosidade por Período</h2>

<p class="text-muted mb-4">
    O gráfico abaixo mostra a <strong>média de luminosidade</strong> registrada pelos sensores
    de cada um dos seus vasos, separada por período do dia:
    <span class="badge" style="background-color:#4FC3F7">Manhã (6h–11:59h)</span>
    <span class="badge" style="background-color:#FFB74D">Tarde (12h–17:59h)</span>
    <span class="badge" style="background-color:#1565C0">Noite (18h–00h)</span>
</p>

<div id="grafico-dashboard"></div>

@section Scripts {
    @* Importando a biblioteca ApexCharts *@
    <script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>

    <script>
        // Nomes dos vasos
        const nomesVasos = @Html.Raw(ViewBag.NomesVasos);

        // Médias de luminosidade por período
        const mediasManha = @Html.Raw(ViewBag.MediasManha);
        const mediasTarde = @Html.Raw(ViewBag.MediasTarde);
        const mediasNoite = @Html.Raw(ViewBag.MediasNoite);

        const options = {

            series: [
                {
                    name: "Manhã", 
                    data: mediasManha
                },
                {
                    name: "Tarde",
                    data: mediasTarde
                },
                {
                    name: "Noite",
                    data: mediasNoite
                }
            ],

            chart: {
                type: "bar",
                height: 420,
                stacked: true,
                toolbar: {
                    show: true
                }
            },

            colors: ["#4FC3F7", "#FFB74D", "#1565C0"],

            xaxis: {
                categories: nomesVasos,
                title: {
                    text: "Vasos"
                }
            },

            yaxis: {
                title: {
                    text: "Média de Luminosidade"
                }
            },

            legend: {
                position: "top",
                horizontalAlign: "center"
            },

            tooltip: {
                y: {
                    formatter: function (val) {
                        return val + " lux";
                    }
                }
            },

            dataLabels: {
                enabled: true,
                formatter: function (val) {
                    return val > 0 ? val : "";
                },
                style: {
                    fontSize: "11px",
                    colors: ["#fff"]
                }
            },

            title: {
                text: "Luminosidade média por período — todos os vasos",
                align: "center",
                style: {
                    fontSize: "14px",
                    fontWeight: "600"
                }
            },

            plotOptions: {
                bar: {
                    horizontal: false,
                    columnWidth: "55%"
                }
            }
        };

        const chart = new ApexCharts(document.querySelector("#grafico-dashboard"), options);
        chart.render();
    </script>
}